generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Project {
  id           String        @id @default(uuid())
  userId       String
  name         String
  pathOrUrl    String
  user         User          @relation(fields: [userId], references: [id])
  vivaSessions VivaSession[]
  createdAt    DateTime      @default(now())
}

model VivaSession {
  id        String   @id @default(uuid())
  projectId String
  score     Float
  feedback  String
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
}
