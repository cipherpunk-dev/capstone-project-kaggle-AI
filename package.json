{
  "name": "mock-viva-cli",
  "version": "1.0.0",
  "description": "A CLI-based multi-agent system designed to act as a mock-viva examiner and code-review assistant.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build:frontend": "cd frontend && npm install && npm run build",
