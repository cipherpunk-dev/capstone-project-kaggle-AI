    "@modelcontextprotocol/sdk": "^1.4.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "inquirer": "^12.3.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "zod": "^3.24.1"
  },
  "author": "",
